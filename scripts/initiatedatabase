/*
=============================================================
Create Database and Schemas
=============================================================
Script Purpose:
    This script creates a new database entitled 'DataWarehouse_Cafe' after checking if it already exists. 
    If the database exists, it is dropped and recreated. Additionally, the script sets up three schemas 
    within the database: 'bronze', 'silver', and 'gold'.
	
WARNING:
    Running this script will drop the entire 'DataWarehouse_Cafe' database if it exists. 
    All data in the database will be permanently deleted. Proceed with caution 
    and ensure you have proper backups before running this script.
*/
-------------------------------------------------------------

IF EXISTS (SELECT 1 FROM sys.databases WHERE name = 'DataWarehouse_Cafe')
BEGIN
    ALTER DATABASE DataWarehouse_Cafe SET SINGLE_USER WITH ROLLBACK IMMEDIATE;
    DROP DATABASE DataWarehouse_Cafe;
END;
GO

-- Create the 'DataWarehouse_Cafe' database
CREATE DATABASE DataWarehouse_Cafe;
GO

USE DataWarehouse_Cafe;
GO

-- Create Schemas
CREATE SCHEMA bronze;
GO

CREATE SCHEMA silver;
GO

CREATE SCHEMA gold;
GO
